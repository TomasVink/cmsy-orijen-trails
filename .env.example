# Production environment variables — set these in Coolify's Environment tab.
# This file is for reference only; it is not read at runtime.
#
# For local Docker testing see .env.local.example instead.

# Full public URL of this deployment, e.g. https://orijen-trails.cmsy.digitalestrateeg.com
PUBLIC_DOMAIN=

# Password for the PostgreSQL service defined in docker-compose.prod.yml.
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=

# Random secret — generate with: openssl rand -hex 32
PAYLOAD_SECRET=

# ── Logto OAuth
LOGTO_ENDPOINT=https://logto.cms.digitalestrateeg.com
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_ORG_ID=
LOGTO_M2M_APP_ID=
LOGTO_M2M_APP_SECRET=

# URL of the cms-platform, e.g. https://cmsy.digitalestrateeg.com
NEXT_PUBLIC_CMS_PLATFORM_URL=

# Slug used to identify this project in the top bar and as a revalidation prefix.
# Must match the subdomain in PUBLIC_DOMAIN (e.g. orijen-trails).
NEXT_PUBLIC_PROJECT_SLUG=

# S3 media storage (leave empty to use local disk)
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto
S3_ENDPOINT=
