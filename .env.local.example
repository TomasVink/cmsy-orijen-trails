# Copy to .env.local and fill in any values you want to override.
# Usage: docker compose -f docker-compose.local.yml --env-file .env.local up --build
#
# All variables below are optional for local testing — sensible defaults are
# already set in docker-compose.local.yml.

# Public URL served by nginx. Change if you bind to a different port or use a
# local domain (e.g. via /etc/hosts + nginx on port 443).
# Default: http://localhost
PUBLIC_DOMAIN=http://localhost

# Payload secret — override to match a real secret if restoring a prod database.
# Default: a local-only placeholder
PAYLOAD_SECRET=

# Port nginx listens on locally. Change if 80 is already in use.
# Default: 80
PORT=80

# ── Logto OAuth (optional) ─────────────────────────────────────────────────────
LOGTO_ENDPOINT=
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_ORG_ID=
LOGTO_M2M_APP_ID=
LOGTO_M2M_APP_SECRET=

# ── cms-platform top bar (optional) ───────────────────────────────────────────
NEXT_PUBLIC_CMS_PLATFORM_URL=
NEXT_PUBLIC_PROJECT_SLUG=

# ── S3 media storage (optional — leave empty to use local disk) ───────────────
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto
S3_ENDPOINT=
