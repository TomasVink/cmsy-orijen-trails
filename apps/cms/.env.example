# Local development only.
# In production all variables are set in Coolify's Environment tab — this file
# is not used during Docker builds or at runtime in production.

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: the Docker Compose postgres started by `bun run dev`
# Production (Coolify): internal URL of the shared postgres, e.g.
#   postgresql://postgres:pass@postgresql-[coolify-id]:5432/payload-[project-slug]
#   The database must be created manually before first deploy — see README Step 6a.
DATABASE_URI=postgresql://payload:payload@localhost:5432/payload

# ── Payload ───────────────────────────────────────────────────────────────────
PAYLOAD_SECRET=          # Generate: openssl rand -hex 32

# Public URL of this CMS app (used for live preview iframes and OAuth redirect URIs)
# Production: set to https://[project-slug].cmsy.digitalestrateeg.com via docker-compose.prod.yml
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Public URL of the SvelteKit frontend (used to embed it in live preview iframes)
# Production: same as NEXT_PUBLIC_SERVER_URL — both apps share the same domain
NEXT_PUBLIC_WEB_URL=http://localhost:5173

# ── Logto OAuth (required when deployed via cms-platform) ─────────────────────
# Logto instance URL
LOGTO_ENDPOINT=https://logto.cms.digitalestrateeg.com

# OIDC app credentials — "Traditional Web" app created in Logto admin
# Redirect URI to register: ${NEXT_PUBLIC_SERVER_URL}/api/users/oauth/logto/callback
LOGTO_APP_ID=
LOGTO_APP_SECRET=

# Logto Organization ID for this project — users must be a member to log in
LOGTO_ORG_ID=

# ── cms-platform top bar ──────────────────────────────────────────────────────
# URL of the cms-platform (e.g. https://cmsy.digitalestrateeg.com)
NEXT_PUBLIC_CMS_PLATFORM_URL=

# Slug used to identify this project in the top bar (e.g. project-x)
NEXT_PUBLIC_PROJECT_SLUG=

# M2M app credentials — "Machine-to-machine" app created in Logto admin
# Required scopes: Management API → all
# Used by the top bar to fetch the user's organizations from the Logto Management API.
# Each organization must have customData.payload_url set to this CMS's URL
# for it to appear in the project switcher.
LOGTO_M2M_APP_ID=
LOGTO_M2M_APP_SECRET=

# ── Bunny CDN cache invalidation (optional) ──────────────────────────────────
# BUNNY_API_KEY=        # Account API key from bunny.net → Account → API
# BUNNY_PULLZONE_ID=    # Pull Zone ID — used to purge all cache on global settings change

# ── S3-compatible media storage (production only) ─────────────────────────────
# Leave blank to use local disk storage (apps/cms/public/media/)
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=auto
# S3_ENDPOINT=        # Required for R2 / B2 / MinIO — omit for standard AWS S3
