# Public URL of the Payload CMS (used by browser for live preview origin validation)
PUBLIC_PAYLOAD_URL=http://localhost:3000

# HERE Maps JavaScript API key — get one at developer.here.com
PUBLIC_HERE_API_KEY=

# Internal URL for SSR fetches — stays on the Docker network, never hits nginx
# Leave unset in local dev (falls back to PUBLIC_PAYLOAD_URL)
# Production: PAYLOAD_INTERNAL_URL=http://cms:3000
PAYLOAD_INTERNAL_URL=

# Comma-separated list of active locales. When only one is set the language
# switcher is hidden and that locale is always used. Defaults to nl,en.
PUBLIC_AVAILABLE_LANGUAGES=nl,en
